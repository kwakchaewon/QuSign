      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cat | grep -q '&& git ' && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"allow\"}}' || echo '{}'"
          }
        ]
      }
    ]
  }
}